# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Generate a long random string: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Build-time (baked into the frontend bundle — rebuild required to change) ──
VITE_SITE_NAME=My Portfolio
VITE_TAGLINE=Creative developer

# ── Host port ─────────────────────────────────────────────────────────────────
# Port exposed on the TrueNAS host. Change if 3001 is already in use.
HOST_PORT=3001
